{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/index.py" },
    { "src": "/docs",          "dest": "/api/index.py" },
    { "src": "/openapi.json",  "dest": "/api/index.py" },
    { "src": "/",              "dest": "/api/index.py" },
    { "src": "/(.*\\.html)",   "dest": "/public/$1" },
    { "src": "/assets/(.*)",   "dest": "/public/assets/$1" },
    { "src": "/(.*)",          "dest": "/public/$1" }
  ]
}
